---
// src/components/MenuItem.astro
const { name, description, price } = Astro.props;
---

<div class="border border-stone-200 rounded-lg p-6 shadow-sm hover:shadow-md transition-shadow bg-white">
  <div class="flex justify-between items-center mb-2">
    <h3 class="text-xl font-semibold text-stone-800">{name}</h3>
    <span class="text-lg font-bold text-emerald-600">{price}</span>
  </div>
  <p class="text-stone-600">{description}</p>
</div>