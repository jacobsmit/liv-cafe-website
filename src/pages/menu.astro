---
// src/pages/menu.astro
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import menuImg from '../assets/2DD07909-9F91-434A-BFC3-2027EA93BCA6_1_201_a.jpeg';
---

<Layout>
	<div class="bg-zinc-950 text-zinc-300 min-h-screen font-sans selection:bg-orange-500 selection:text-white">
		<header class="relative py-20 px-4 border-b border-zinc-800">
			<div class="max-w-4xl mx-auto text-center">
				<h1 class="text-5xl md:text-6xl font-serif text-white mb-4 tracking-wide">Our Menu</h1>
				<div class="w-16 h-[2px] bg-orange-500 mx-auto"></div>
			</div>
		</header>

		<main class="max-w-6xl mx-auto py-20 px-4">
			<!-- Featured Dish Section -->
			<section class="mb-24 bg-zinc-900 rounded-sm overflow-hidden shadow-2xl border border-zinc-800">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-0">
					<div class="h-80 md:h-full overflow-hidden group">
						<Image src={menuImg} width={800} alt="Featured Dish" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
					</div>
					<div class="p-12 flex flex-col justify-center">
						<h2 class="text-3xl font-serif text-white mb-4">Culinary Excellence</h2>
						<p class="text-zinc-300 leading-relaxed mb-6 font-light text-xl">
							Every dish is crafted with meticulous attention to detail, using seasonal ingredients from our own farm.
						</p>
						<p class="text-zinc-300 text-lg italic border-l-4 border-orange-500 pl-4">
							"A creative blend of tradition and innovation."
						</p>
					</div>
				</div>
			</section>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-16">
				<!-- Left Column -->
				<section class="mb-16 md:mb-0">
					<h2 class="text-3xl font-serif text-white mb-6">Dine In</h2>
					<p class="text-zinc-300 leading-relaxed mb-8 text-xl">
						Explore our ever-changing seasonal menus celebrating fresh, local ingredients.
					</p>
					<ul class="text-zinc-300 leading-relaxed space-y-8">
						<li class="bg-zinc-900 border border-zinc-800 p-6 rounded-sm shadow-lg border-l-4 border-l-orange-500">
							<h3 class="font-serif text-3xl text-white mb-2">Bistro Lunch Menu</h3>
							<p class="text-zinc-400 text-lg mb-6">Casual elegance for your midday break</p>
							<a href={`${import.meta.env.BASE_URL}/menus/LIV_Modern_Menu_Design.pdf`} target="_blank" rel="noopener noreferrer" class="inline-block bg-orange-500 text-white font-semibold px-8 py-3 rounded hover:bg-orange-600 transition-colors shadow-sm text-center w-full md:w-auto">View Lunch Menu</a>
						</li>
						<li class="bg-zinc-900 border border-zinc-800 p-6 rounded-sm shadow-lg border-l-4 border-l-orange-500">
							<h3 class="font-serif text-3xl text-white mb-2">Weekend Brunch Menu</h3>
							<p class="text-zinc-400 text-lg mb-6">Leisurely dining at its finest</p>
							<a href={`${import.meta.env.BASE_URL}/menus/LIV_Weekend_Brunch_Menu.pdf`} target="_blank" rel="noopener noreferrer" class="inline-block bg-orange-500 text-white font-semibold px-8 py-3 rounded hover:bg-orange-600 transition-colors shadow-sm text-center w-full md:w-auto">View Brunch Menu</a>
						</li>
						<li class="bg-zinc-900 border border-zinc-800 p-6 rounded-sm shadow-lg border-l-4 border-l-zinc-700 opacity-80">
							<h3 class="font-serif text-3xl text-white mb-2">Dinner Menu</h3>
							<p class="text-zinc-400 text-lg mb-6">An evening of culinary artistry</p>
							<a href="#" class="inline-block bg-zinc-700 text-zinc-300 font-semibold px-8 py-3 rounded cursor-default text-center w-full md:w-auto">Coming Soon</a>
						</li>
					</ul>
				</section>

				<!-- Right Column -->
				<section>
					<h2 class="text-3xl font-serif text-white mb-6">Dietary Notes</h2>
					<div class="bg-zinc-900 rounded-sm p-8 border border-zinc-800 mb-8">
						<ul class="text-zinc-300 leading-relaxed space-y-4">
							<li class="flex items-center gap-3">
								<span class="text-orange-500 font-bold">#gf</span>
								<span>Gluten Free</span>
							</li>
							<li class="flex items-center gap-3">
								<span class="text-orange-500 font-bold">#gf A</span>
								<span>Gluten Free Available</span>
							</li>
							<li class="flex items-center gap-3">
								<span class="text-orange-500 font-bold">#vegan A</span>
								<span>Vegan Available</span>
							</li>
							<li class="flex items-center gap-3">
								<span class="text-orange-500 font-bold">#veg</span>
								<span>Vegetarian</span>
							</li>
						</ul>
					</div>

					<h2 class="text-3xl font-serif text-white mb-6">Our Philosophy</h2>
					<div class="border-l-2 border-orange-500 pl-6">
						<p class="text-zinc-300 leading-relaxed text-xl">
							Our menu changes seasonally to reflect what grows locally. From our farm in Saanich to your plate, every ingredient is chosen with care.
						</p>
					</div>
				</section>
			</div>
		</main>
	</div>
</Layout>
