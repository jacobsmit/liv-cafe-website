---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<header class="bg-stone-200 py-12 text-center px-4">
		<h1 class="text-4xl font-bold text-stone-800">Reservations</h1>
	</header>

	<main class="max-w-4xl mx-auto py-16 px-4">
		<section class="mb-12">
			<h2 class="text-2xl font-bold mb-4 text-stone-800">Get In Touch</h2>
			<p class="text-stone-600 leading-relaxed mb-6">
				To make a reservation, please call us or send us a message with your details below.
			</p>
			
			<div class="mb-8">
				<h3 class="text-lg font-bold mb-2 text-stone-800">Call Us</h3>
				<p class="text-stone-600">
					<a href="tel:(250) 590-5229" class="text-emerald-600 hover:underline">(250) 590-5229</a>
				</p>
			</div>

			<div class="mb-8">
				<h3 class="text-lg font-bold mb-2 text-stone-800">Email Us</h3>
				<p class="text-stone-600">
					<a href="mailto:info@livcafeandbistro.com" class="text-emerald-600 hover:underline">info@livcafeandbistro.com</a>
				</p>
			</div>
		</section>

		<section class="mb-12">
			<h2 class="text-2xl font-bold mb-6 text-stone-800">Reservation Form</h2>
			<p class="text-stone-600 mb-6 text-sm">
				Fill out the form below and we'll get back to you as soon as possible to confirm your reservation.
			</p>
			<form action="https://formspree.io/f/mzdokbnq" method="POST" class="space-y-4">
				<input type="hidden" name="_subject" value="New Reservation Request" />
				<input type="hidden" name="_captcha" value="false" />
				
				<div>
					<label class="block text-stone-700 font-bold mb-2">Name <span class="text-red-500">*</span></label>
					<input type="text" name="name" placeholder="Your name" required class="w-full px-4 py-2 border border-stone-300 rounded" />
				</div>
				
				<div>
					<label class="block text-stone-700 font-bold mb-2">Phone <span class="text-red-500">*</span></label>
					<input type="tel" name="phone" placeholder="Your phone number" required class="w-full px-4 py-2 border border-stone-300 rounded" />
				</div>
				
				<div>
					<label class="block text-stone-700 font-bold mb-2">Email <span class="text-red-500">*</span></label>
					<input type="email" name="email" placeholder="Your email" required class="w-full px-4 py-2 border border-stone-300 rounded" />
				</div>
				
				<div>
					<label class="block text-stone-700 font-bold mb-2">Day & Time <span class="text-red-500">*</span></label>
					<input type="datetime-local" name="date_time" required class="w-full px-4 py-2 border border-stone-300 rounded" />
				</div>
				
				<div>
					<label class="block text-stone-700 font-bold mb-2">Number of People <span class="text-red-500">*</span></label>
					<input type="number" name="number_of_people" placeholder="Party size" min="1" required class="w-full px-4 py-2 border border-stone-300 rounded" />
				</div>
				
				<div>
					<label class="block text-stone-700 font-bold mb-2">Message</label>
					<textarea name="message" placeholder="Any special requests..." rows="4" class="w-full px-4 py-2 border border-stone-300 rounded"></textarea>
				</div>
				
				<button type="submit" class="bg-emerald-600 text-white px-6 py-2 rounded hover:bg-emerald-700">
					Send Reservation Request
				</button>
			</form>
		</section>
	</main>
</Layout>
