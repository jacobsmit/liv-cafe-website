---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<div class="bg-zinc-950 text-zinc-300 min-h-screen font-sans selection:bg-orange-500 selection:text-white">
		<header class="relative py-20 px-4 border-b border-zinc-800">
			<div class="max-w-4xl mx-auto text-center">
				<h1 class="text-5xl md:text-6xl font-serif text-white mb-4 tracking-wide">Reservations</h1>
				<div class="w-16 h-[2px] bg-orange-500 mx-auto"></div>
			</div>
		</header>

		<main class="max-w-5xl mx-auto py-20 px-4">
			<div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-24">
				<!-- Quick Contact Cards -->
				<section class="md:col-span-1">
					<h2 class="text-3xl font-serif text-white mb-8">Get In Touch</h2>
					<div class="space-y-6">
						<div class="bg-orange-500 p-8 rounded-sm shadow-lg border-2 border-orange-500 text-center">
							<h3 class="text-white font-serif text-2xl mb-4 font-semibold">Prefer to Call?</h3>
							<p class="mb-2">
								<a href="tel:2505905229" class="text-white font-bold text-3xl hover:text-zinc-100 transition-colors block py-2">(250) 590-5229</a>
							</p>
							<p class="text-orange-100 text-sm font-medium">Available during business hours</p>
						</div>

						<div class="bg-zinc-900 p-8 rounded-sm border border-zinc-800">
							<h3 class="text-orange-500 font-serif text-lg mb-4">Email Us</h3>
							<p class="text-zinc-300 leading-relaxed mb-2">
								<a href="mailto:info@livcafeandbistro.com" class="text-orange-500 hover:text-orange-400 transition-colors break-all">info@livcafeandbistro.com</a>
							</p>
							<p class="text-zinc-400 text-sm">We'll respond within 24 hours</p>
						</div>

						<div class="bg-zinc-900 p-8 rounded-sm border border-zinc-800">
							<h3 class="text-orange-500 font-serif text-lg mb-4">Visit Us</h3>
							<p class="text-zinc-300 leading-relaxed mb-2">
								713 St. Patrick Street<br />
								Victoria, BC
							</p>
							<p class="text-zinc-400 text-sm">Heart of Oak Bay</p>
						</div>
					</div>
				</section>

				<!-- Reservation Form -->
				<section class="md:col-span-2">
					<h2 class="text-3xl font-serif text-white mb-8">Make a Reservation</h2>
					<p class="text-zinc-400 mb-8">
						Fill out the form below and we'll get back to you as soon as possible to confirm your reservation.
					</p>
					<form id="reservation_form" action="https://formspree.io/f/mzdokbnq" method="POST" class="space-y-6">
						<input type="hidden" name="_subject" value="New Reservation Request from Liv Café" />
						<input type="hidden" name="_captcha" value="false" />
						
						<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
							<div>
								<label class="block text-white font-bold text-lg mb-3">Name <span class="text-orange-500">*</span></label>
								<input type="text" name="name" placeholder="Your name" required class="w-full px-6 py-4 bg-zinc-900 border-2 border-zinc-700 text-white text-lg placeholder-zinc-500 rounded focus:border-orange-500 focus:outline-none transition-colors shadow-sm" />
							</div>
							
							<div>
								<label class="block text-white font-bold text-lg mb-3">Phone <span class="text-orange-500">*</span></label>
								<input type="tel" name="phone" placeholder="(250) 590-5229" required class="w-full px-6 py-4 bg-zinc-900 border-2 border-zinc-700 text-white text-lg placeholder-zinc-500 rounded focus:border-orange-500 focus:outline-none transition-colors shadow-sm" />
							</div>
						</div>
						
						<div class="mt-8">
							<label class="block text-white font-bold text-lg mb-3">Email <span class="text-orange-500">*</span></label>
							<input type="email" name="email" placeholder="your@email.com" required class="w-full px-6 py-4 bg-zinc-900 border-2 border-zinc-700 text-white text-lg placeholder-zinc-500 rounded focus:border-orange-500 focus:outline-none transition-colors shadow-sm" />
						</div>
						
						<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-8">
							<div>
								<label class="block text-white font-bold text-lg mb-3">Date <span class="text-orange-500">*</span></label>
								<input type="date" name="date" id="reservation_date" required class="w-full px-6 py-4 bg-zinc-900 border-2 border-zinc-700 text-white text-lg rounded focus:border-orange-500 focus:outline-none transition-colors shadow-sm" />
							</div>
							
							<div>
								<label class="block text-white font-bold text-lg mb-3">Time <span class="text-orange-500">*</span></label>
								<select name="time" id="reservation_time" required disabled class="w-full px-6 py-4 bg-zinc-900 border-2 border-zinc-700 text-white text-lg rounded focus:border-orange-500 focus:outline-none transition-colors shadow-sm appearance-none disabled:opacity-50 cursor-pointer disabled:cursor-not-allowed">
									<option value="" disabled selected>Select date first</option>
								</select>
							</div>

							<div>
								<label class="block text-white font-bold text-lg mb-3">Party Size <span class="text-orange-500">*</span></label>
								<input type="number" name="number_of_people" placeholder="1-12" min="1" max="12" required class="w-full px-6 py-4 bg-zinc-900 border-2 border-zinc-700 text-white text-lg placeholder-zinc-500 rounded focus:border-orange-500 focus:outline-none transition-colors shadow-sm" />
							</div>
						</div>
						<div id="date_error_msg" class="text-orange-500 font-bold hidden -mt-4"></div>
						
						<div class="mt-8">
							<label class="block text-white font-bold text-lg mb-3">Type of Event (Optional)</label>
							<input type="text" name="event_type" placeholder="e.g. Birthday, Anniversary, Business" class="w-full px-6 py-4 bg-zinc-900 border-2 border-zinc-700 text-white text-lg placeholder-zinc-500 rounded focus:border-orange-500 focus:outline-none transition-colors shadow-sm" />
						</div>

						<div class="mt-8">
							<label class="block text-white font-bold text-lg mb-3">Are there any special food requests or allergies? (Optional)</label>
							<textarea name="food_requests" placeholder="Please list any dietary requirements or allergies" rows="2" class="w-full px-6 py-4 bg-zinc-900 border-2 border-zinc-700 text-white text-lg placeholder-zinc-500 rounded focus:border-orange-500 focus:outline-none transition-colors resize-none shadow-sm"></textarea>
						</div>
						
						<button type="submit" class="w-full bg-orange-500 text-white px-8 py-5 mt-10 rounded font-bold text-xl hover:bg-orange-600 transition-colors shadow-lg">
							Send Reservation Request
						</button>
					</form>
				</section>
			</div>
		</main>
	</div>

	<script>
		document.addEventListener('DOMContentLoaded', () => {
			const dateInput = document.getElementById('reservation_date');
			const timeSelect = document.getElementById('reservation_time');
			const form = document.getElementById('reservation_form');
			const errorMsg = document.getElementById('date_error_msg');
			
			if (!dateInput || !timeSelect || !form || !errorMsg) return;
			
			// Set min date to today in local time
			const today = new Date();
			const yyyy = today.getFullYear();
			const mm = String(today.getMonth() + 1).padStart(2, '0');
			const dd = String(today.getDate()).padStart(2, '0');
			dateInput.min = `${yyyy}-${mm}-${dd}`;

			function updateTimes() {
				timeSelect.innerHTML = '<option value="" disabled selected>Select a time</option>';
				errorMsg.classList.add('hidden');
				timeSelect.disabled = true;

				if (!dateInput.value) return;

				// Parse date securely as local time to avoid timezone offset bugs
				const [year, month, dayStr] = dateInput.value.split('-');
				const selectedDate = new Date(year, month - 1, dayStr);
				const day = selectedDate.getDay(); // 0 = Sun, 1 = Mon, ..., 6 = Sat

				if (day === 1 || day === 2) {
					errorMsg.textContent = 'Sorry, we are closed on Mondays and Tuesdays.';
					errorMsg.classList.remove('hidden');
					return;
				}

				let availableTimes = [];
				
				// Brunch/Lunch (Wed-Sun)
				if (day >= 3 || day === 0) { 
					let startHour = (day === 0 || day === 6) ? 9 : 10;
					let startMin = (day === 0 || day === 6) ? 30 : 0;
					
					// Up to 14:00 (closes at 2:30pm)
					let h = startHour, m = startMin;
					while (h < 14 || (h === 14 && m === 0)) {
						const displayH = h > 12 ? h - 12 : h;
						const mm = String(m).padStart(2, '0');
						const timeStr = `${displayH}:${mm} ${h >= 12 ? 'PM' : 'AM'}`;
						availableTimes.push({ val: `${h}:${mm}`, label: timeStr });
						m += 15;
						if (m >= 60) { m -= 60; h++; }
					}
				}

				// Dinner (Thu, Fri, Sat)
				if (day >= 4 && day <= 6) {
					let h = 17, m = 0;
					// Up to 8:30 PM (closes at 9:00pm)
					while (h < 20 || (h === 20 && m <= 30)) {
						const displayH = h > 12 ? h - 12 : h;
						const mm = String(m).padStart(2, '0');
						const timeStr = `${displayH}:${mm} PM`;
						availableTimes.push({ val: `${h}:${mm}`, label: timeStr });
						m += 15;
						if (m >= 60) { m -= 60; h++; }
					}
				}

				// If selected date is today, filter out past times
				const isToday = dateInput.value === `${yyyy}-${mm}-${dd}`;
				const currentHour = today.getHours();
				const currentMin = today.getMinutes();

				if (isToday) {
					availableTimes = availableTimes.filter(t => {
						const [th, tm] = t.val.split(':').map(Number);
						if (th < currentHour) return false;
						if (th === currentHour && tm <= currentMin) return false;
						return true;
					});
					if (availableTimes.length === 0) {
						errorMsg.textContent = 'No available times left for today. Please select another date.';
						errorMsg.classList.remove('hidden');
						return;
					}
				}

				availableTimes.forEach(t => {
					const opt = document.createElement('option');
					opt.value = t.label;
					opt.textContent = t.label;
					timeSelect.appendChild(opt);
				});

				timeSelect.disabled = false;
			}

			dateInput.addEventListener('change', updateTimes);
			
			form.addEventListener('submit', (e) => {
				if (timeSelect.disabled || !timeSelect.value) {
					e.preventDefault();
					errorMsg.textContent = 'Please select a valid date and time before submitting.';
					errorMsg.classList.remove('hidden');
				}
			});
		});
	</script>
</Layout>
