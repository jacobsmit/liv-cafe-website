---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<div class="bg-zinc-950 text-zinc-300 min-h-screen font-sans selection:bg-orange-500 selection:text-white">
		<header class="relative py-20 px-4 border-b border-zinc-800">
			<div class="max-w-4xl mx-auto text-center">
				<h1 class="text-5xl md:text-6xl font-serif text-white mb-4 tracking-wide">Reservations</h1>
				<div class="w-16 h-[2px] bg-orange-500 mx-auto"></div>
			</div>
		</header>

		<main class="max-w-4xl mx-auto py-20 px-4">
			<section class="mb-16">
				<h2 class="text-3xl font-serif text-white mb-6">Get In Touch</h2>
				<p class="text-zinc-300 leading-relaxed mb-8">
					To make a reservation, please call us or send us a message with your details below.
				</p>
				
				<div class="grid md:grid-cols-2 gap-8 mb-8">
					<div class="border-l-2 border-orange-500 pl-6">
						<h3 class="text-orange-500 font-serif text-lg mb-3">Call Us</h3>
						<p class="text-zinc-300">
							<a href="tel:(250) 590-5229" class="text-orange-500 hover:text-orange-400 transition-colors">(250) 590-5229</a>
						</p>
					</div>

					<div class="border-l-2 border-orange-500 pl-6">
						<h3 class="text-orange-500 font-serif text-lg mb-3">Email Us</h3>
						<p class="text-zinc-300">
							<a href="mailto:info@livcafeandbistro.com" class="text-orange-500 hover:text-orange-400 transition-colors">info@livcafeandbistro.com</a>
						</p>
					</div>
				</div>
			</section>

			<section>
				<h2 class="text-3xl font-serif text-white mb-8">Reservation Form</h2>
				<p class="text-zinc-400 mb-8 text-sm">
					Fill out the form below and we'll get back to you as soon as possible to confirm your reservation.
				</p>
				<form action="https://formspree.io/f/mzdokbnq" method="POST" class="space-y-6">
					<input type="hidden" name="_subject" value="New Reservation Request from Liv Café" />
					<input type="hidden" name="_captcha" value="false" />
					
					<div>
						<label class="block text-zinc-300 font-serif mb-2">Name <span class="text-orange-500">*</span></label>
						<input type="text" name="name" placeholder="Your name" required class="w-full px-4 py-3 bg-zinc-900 border border-zinc-800 text-zinc-300 placeholder-zinc-600 rounded focus:border-orange-500 focus:outline-none transition-colors" />
					</div>
					
					<div>
						<label class="block text-zinc-300 font-serif mb-2">Phone <span class="text-orange-500">*</span></label>
						<input type="tel" name="phone" placeholder="Your phone number" required class="w-full px-4 py-3 bg-zinc-900 border border-zinc-800 text-zinc-300 placeholder-zinc-600 rounded focus:border-orange-500 focus:outline-none transition-colors" />
					</div>
					
					<div>
						<label class="block text-zinc-300 font-serif mb-2">Email <span class="text-orange-500">*</span></label>
						<input type="email" name="email" placeholder="Your email" required class="w-full px-4 py-3 bg-zinc-900 border border-zinc-800 text-zinc-300 placeholder-zinc-600 rounded focus:border-orange-500 focus:outline-none transition-colors" />
					</div>
					
					<div>
						<label class="block text-zinc-300 font-serif mb-2">Day & Time <span class="text-orange-500">*</span></label>
						<input type="datetime-local" name="date_time" required class="w-full px-4 py-3 bg-zinc-900 border border-zinc-800 text-zinc-300 rounded focus:border-orange-500 focus:outline-none transition-colors" />
					</div>
					
					<div>
						<label class="block text-zinc-300 font-serif mb-2">Number of People <span class="text-orange-500">*</span></label>
						<input type="number" name="number_of_people" placeholder="Party size" min="1" required class="w-full px-4 py-3 bg-zinc-900 border border-zinc-800 text-zinc-300 placeholder-zinc-600 rounded focus:border-orange-500 focus:outline-none transition-colors" />
					</div>
					
					<div>
						<label class="block text-zinc-300 font-serif mb-2">Message</label>
						<textarea name="message" placeholder="Any special requests..." rows="4" class="w-full px-4 py-3 bg-zinc-900 border border-zinc-800 text-zinc-300 placeholder-zinc-600 rounded focus:border-orange-500 focus:outline-none transition-colors"></textarea>
					</div>
					
					<button type="submit" class="w-full bg-orange-500 text-white px-6 py-3 rounded hover:bg-orange-600 transition-colors font-serif tracking-wide">
						Send Reservation Request
					</button>
				</form>
			</section>
		</main>
	</div>
</Layout>
