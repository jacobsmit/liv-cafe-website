---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<div class="bg-zinc-950 text-zinc-300 min-h-screen font-sans selection:bg-orange-500 selection:text-white">
		<header class="relative py-20 px-4 border-b border-zinc-800">
			<div class="max-w-4xl mx-auto text-center">
				<h1 class="text-5xl md:text-6xl font-serif text-white mb-4 tracking-wide">Reservations</h1>
				<div class="w-16 h-[2px] bg-orange-500 mx-auto"></div>
			</div>
		</header>

		<main class="max-w-5xl mx-auto py-20 px-4">
			<div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-24">
				<!-- Quick Contact Cards -->
				<section class="md:col-span-1">
					<h2 class="text-3xl font-serif text-white mb-8">Get In Touch</h2>
					<div class="space-y-6">
						<div class="bg-zinc-900 p-8 rounded-sm border border-zinc-800">
							<h3 class="text-orange-500 font-serif text-lg mb-4">Call Us</h3>
							<p class="text-zinc-300 leading-relaxed mb-2">
								<a href="tel:(250) 590-5229" class="text-orange-500 hover:text-orange-400 transition-colors font-serif text-lg">(250) 590-5229</a>
							</p>
							<p class="text-zinc-400 text-sm">Available during business hours</p>
						</div>

						<div class="bg-zinc-900 p-8 rounded-sm border border-zinc-800">
							<h3 class="text-orange-500 font-serif text-lg mb-4">Email Us</h3>
							<p class="text-zinc-300 leading-relaxed mb-2">
								<a href="mailto:info@livcafeandbistro.com" class="text-orange-500 hover:text-orange-400 transition-colors break-all">info@livcafeandbistro.com</a>
							</p>
							<p class="text-zinc-400 text-sm">We'll respond within 24 hours</p>
						</div>

						<div class="bg-zinc-900 p-8 rounded-sm border border-zinc-800">
							<h3 class="text-orange-500 font-serif text-lg mb-4">Visit Us</h3>
							<p class="text-zinc-300 leading-relaxed mb-2">
								713 St. Patrick Street<br />
								Victoria, BC
							</p>
							<p class="text-zinc-400 text-sm">Heart of Oak Bay</p>
						</div>
					</div>
				</section>

				<!-- Reservation Form -->
				<section class="md:col-span-2">
					<h2 class="text-3xl font-serif text-white mb-8">Make a Reservation</h2>
					<p class="text-zinc-400 mb-8">
						Fill out the form below and we'll get back to you as soon as possible to confirm your reservation.
					</p>
					<form action="https://formspree.io/f/mzdokbnq" method="POST" class="space-y-6">
						<input type="hidden" name="_subject" value="New Reservation Request from Liv Café" />
						<input type="hidden" name="_captcha" value="false" />
						
						<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
							<div>
								<label class="block text-zinc-300 font-serif mb-2">Name <span class="text-orange-500">*</span></label>
								<input type="text" name="name" placeholder="Your name" required class="w-full px-4 py-3 bg-zinc-900 border border-zinc-800 text-zinc-300 placeholder-zinc-600 rounded focus:border-orange-500 focus:outline-none transition-colors" />
							</div>
							
							<div>
								<label class="block text-zinc-300 font-serif mb-2">Phone <span class="text-orange-500">*</span></label>
								<input type="tel" name="phone" placeholder="(250) 590-5229" required class="w-full px-4 py-3 bg-zinc-900 border border-zinc-800 text-zinc-300 placeholder-zinc-600 rounded focus:border-orange-500 focus:outline-none transition-colors" />
							</div>
						</div>
						
						<div>
							<label class="block text-zinc-300 font-serif mb-2">Email <span class="text-orange-500">*</span></label>
							<input type="email" name="email" placeholder="your@email.com" required class="w-full px-4 py-3 bg-zinc-900 border border-zinc-800 text-zinc-300 placeholder-zinc-600 rounded focus:border-orange-500 focus:outline-none transition-colors" />
						</div>
						
						<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
							<div>
								<label class="block text-zinc-300 font-serif mb-2">Date & Time <span class="text-orange-500">*</span></label>
								<input type="datetime-local" name="date_time" required class="w-full px-4 py-3 bg-zinc-900 border border-zinc-800 text-zinc-300 rounded focus:border-orange-500 focus:outline-none transition-colors" />
							</div>
							
							<div>
								<label class="block text-zinc-300 font-serif mb-2">Number of People <span class="text-orange-500">*</span></label>
								<input type="number" name="number_of_people" placeholder="Party size" min="1" max="12" required class="w-full px-4 py-3 bg-zinc-900 border border-zinc-800 text-zinc-300 placeholder-zinc-600 rounded focus:border-orange-500 focus:outline-none transition-colors" />
							</div>
						</div>
						
						<div>
							<label class="block text-zinc-300 font-serif mb-2">Message</label>
							<textarea name="message" placeholder="Any special requests or dietary requirements?" rows="4" class="w-full px-4 py-3 bg-zinc-900 border border-zinc-800 text-zinc-300 placeholder-zinc-600 rounded focus:border-orange-500 focus:outline-none transition-colors resize-none"></textarea>
						</div>
						
						<button type="submit" class="w-full bg-orange-500 text-white px-6 py-3 rounded hover:bg-orange-600 transition-colors font-serif tracking-wide uppercase text-sm">
							Send Reservation Request
						</button>
					</form>
				</section>
			</div>
		</main>
	</div>
</Layout>
