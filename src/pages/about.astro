---
// src/pages/about.astro
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import mainbowlImg from '../assets/mainbowl.JPG';
---

<Layout>
	<div class="bg-zinc-950 text-zinc-300 min-h-screen font-sans selection:bg-orange-500 selection:text-white">
		<header class="relative py-20 px-4 border-b border-zinc-800">
			<div class="max-w-4xl mx-auto text-center">
				<h1 class="text-5xl md:text-6xl font-serif text-white mb-4 tracking-wide">About</h1>
				<div class="w-16 h-[2px] bg-orange-500 mx-auto"></div>
			</div>
		</header>

		<main class="max-w-6xl mx-auto py-20 px-4">
			<!-- Philosophy, Seasonal Menus & Edible Gardens Section with Image -->
			<section class="mb-24 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
				<div class="h-96 rounded-sm shadow-2xl overflow-hidden group order-2 md:order-1">
					<Image src={mainbowlImg} alt="Our philosophy and farm-to-table ingredients" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
				</div>
				<div class="order-1 md:order-2 space-y-12">
					<div>
						<h2 class="text-4xl font-serif text-white mb-6">Our Philosophy</h2>
						<div class="border-l-4 border-orange-500 pl-6 space-y-6">
							<p class="text-zinc-300 leading-relaxed text-2xl font-light">
								A cocoon to live a little. Nestled within Oak Bay, Liv is an ingredient-driven restaurant founded by Chefs Louise Lu and Milton Rebello.
							</p>
						</div>
					</div>

					<div>
						<h2 class="text-3xl font-serif text-white mb-6">Seasonal Menus & Edible Gardens</h2>
						<div class="border-l-4 border-orange-500 pl-6 space-y-6">
							<p class="text-zinc-300 leading-relaxed text-xl font-light">
								Our menu changes seasonally, reflecting what grows locally. Most produce is homegrown from our own farm in Saanich, 'Liv's Edible Gardens'. We believe in creating exceptional experiences through sustainable, locally-sourced ingredients.
							</p>
						</div>
					</div>
				</div>
			</section>
		</main>
	</div>
</Layout>
