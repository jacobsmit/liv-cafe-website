---
// src/pages/catering.astro
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<div class="bg-zinc-950 text-zinc-300 min-h-screen font-sans selection:bg-orange-500 selection:text-white">
		<header class="relative py-20 px-4 border-b border-zinc-800">
			<div class="max-w-4xl mx-auto text-center">
				<h1 class="text-5xl md:text-6xl font-serif text-white mb-4 tracking-wide">Catering</h1>
				<div class="w-16 h-[2px] bg-orange-500 mx-auto"></div>
			</div>
		</header>

		<main class="max-w-4xl mx-auto py-20 px-4">
			<section class="mb-16">
				<h2 class="text-3xl font-serif text-white mb-6">Chef Driven Catering</h2>
				<div class="border-l-2 border-orange-500 pl-6 space-y-4">
					<p class="text-zinc-300 leading-relaxed">
						From small intimate gatherings to chef-driven five-course dinners at your home or any venue in and surrounding Oak Bay and Greater Victoria, we are passionate about what we do, and we strive to ensure all our celebrations are exceptional.
					</p>
					<p class="text-white font-serif text-lg">
						We bring fine dining to you!
					</p>
				</div>
			</section>

			<section class="mb-16">
				<h2 class="text-3xl font-serif text-white mb-6">Our Offerings</h2>
				<ul class="text-zinc-300 leading-relaxed space-y-3 border-l-2 border-orange-500 pl-6">
					<li><span class="text-orange-500">•</span> Canapés & Appetizers</li>
					<li><span class="text-orange-500">•</span> Charcuterie Boards</li>
					<li><span class="text-orange-500">•</span> Dessert Platters</li>
					<li><span class="text-orange-500">•</span> Family Style Dinners</li>
					<li><span class="text-orange-500">•</span> Custom Multi-Course Menus</li>
				</ul>
			</section>

			<section class="mb-16">
				<h2 class="text-3xl font-serif text-white mb-6">Philosophy</h2>
				<div class="border-l-2 border-orange-500 pl-6">
					<p class="text-orange-500 font-serif text-xl mb-3">
						Farm Fueled ~ Chef Driven
					</p>
					<p class="text-zinc-300 leading-relaxed">
						All our catering uses the same philosophy as our restaurant: seasonal, locally sourced, and beautifully presented. We believe in creating memorable experiences through exceptional food.
					</p>
				</div>
			</section>

			<section class="mb-16">
				<h2 class="text-3xl font-serif text-white mb-6">Book Your Event</h2>
				<p class="text-zinc-300 leading-relaxed mb-8">
					For more information about our catering services and custom menus, please reach out:
				</p>
				
				<div class="grid md:grid-cols-2 gap-8">
					<div class="border-l-2 border-orange-500 pl-6">
						<h3 class="text-orange-500 font-serif text-lg mb-3">Contact Us</h3>
						<p class="text-zinc-300 mb-2">
							<a href="tel:(250) 590-5229" class="text-orange-500 hover:text-orange-400 transition-colors">(250) 590-5229</a>
						</p>
						<p class="text-zinc-300">
							<a href="mailto:info@livcafeandbistro.com" class="text-orange-500 hover:text-orange-400 transition-colors">info@livcafeandbistro.com</a>
						</p>
					</div>
				</div>
			</section>

			<section>
				<h2 class="text-3xl font-serif text-white mb-8">Catering Inquiry Form</h2>
				<p class="text-zinc-400 mb-8 text-sm">
					Tell us about your event and we'll be in touch with catering options and pricing.
				</p>
				<form action="https://formspree.io/f/mzdokbnq" method="POST" class="space-y-6">
					<input type="hidden" name="_subject" value="New Catering Inquiry from Liv Café" />
					<input type="hidden" name="_captcha" value="false" />
					
					<div>
						<label class="block text-zinc-300 font-serif mb-2">Name <span class="text-orange-500">*</span></label>
						<input type="text" name="name" placeholder="Your name" required class="w-full px-4 py-3 bg-zinc-900 border border-zinc-800 text-zinc-300 placeholder-zinc-600 rounded focus:border-orange-500 focus:outline-none transition-colors" />
					</div>
					
					<div>
						<label class="block text-zinc-300 font-serif mb-2">Phone <span class="text-orange-500">*</span></label>
						<input type="tel" name="phone" placeholder="Your phone number" required class="w-full px-4 py-3 bg-zinc-900 border border-zinc-800 text-zinc-300 placeholder-zinc-600 rounded focus:border-orange-500 focus:outline-none transition-colors" />
					</div>
					
					<div>
						<label class="block text-zinc-300 font-serif mb-2">Email <span class="text-orange-500">*</span></label>
						<input type="email" name="email" placeholder="Your email" required class="w-full px-4 py-3 bg-zinc-900 border border-zinc-800 text-zinc-300 placeholder-zinc-600 rounded focus:border-orange-500 focus:outline-none transition-colors" />
					</div>
					
					<div>
						<label class="block text-zinc-300 font-serif mb-2">Date & Time of Event <span class="text-orange-500">*</span></label>
						<input type="datetime-local" name="event_date_time" required class="w-full px-4 py-3 bg-zinc-900 border border-zinc-800 text-zinc-300 rounded focus:border-orange-500 focus:outline-none transition-colors" />
					</div>
					
					<div>
						<label class="block text-zinc-300 font-serif mb-2">Type of Celebration <span class="text-orange-500">*</span></label>
						<input type="text" name="event_type" placeholder="e.g., Wedding, Birthday, Corporate Event" required class="w-full px-4 py-3 bg-zinc-900 border border-zinc-800 text-zinc-300 placeholder-zinc-600 rounded focus:border-orange-500 focus:outline-none transition-colors" />
					</div>
					
					<div>
						<label class="block text-zinc-300 font-serif mb-2">Number of Guests <span class="text-orange-500">*</span></label>
						<input type="number" name="guest_count" placeholder="Guest count" min="1" required class="w-full px-4 py-3 bg-zinc-900 border border-zinc-800 text-zinc-300 placeholder-zinc-600 rounded focus:border-orange-500 focus:outline-none transition-colors" />
					</div>
					
					<div>
						<label class="block text-zinc-300 font-serif mb-2">Details & Special Requests</label>
						<textarea name="details" placeholder="Tell us about your event..." rows="4" class="w-full px-4 py-3 bg-zinc-900 border border-zinc-800 text-zinc-300 placeholder-zinc-600 rounded focus:border-orange-500 focus:outline-none transition-colors"></textarea>
					</div>
					
					<button type="submit" class="w-full bg-orange-500 text-white px-6 py-3 rounded hover:bg-orange-600 transition-colors font-serif tracking-wide">
						Submit Catering Inquiry
					</button>
				</form>
			</section>
		</main>
	</div>
</Layout>
