---
// src/pages/catering.astro
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import cateringImg from '../assets/3BC55C12-0B88-4826-A269-3F37B56D2F06_1_201_a.jpeg';
---

<Layout>
	<div class="bg-zinc-950 text-zinc-300 min-h-screen font-sans selection:bg-orange-500 selection:text-white">
		<header class="relative py-20 px-4 border-b border-zinc-800">
			<div class="max-w-4xl mx-auto text-center">
				<h1 class="text-5xl md:text-6xl font-serif text-white mb-4 tracking-wide">Catering</h1>
				<div class="w-16 h-[2px] bg-orange-500 mx-auto"></div>
			</div>
		</header>

		<main class="max-w-6xl mx-auto py-20 px-4">
			<!-- Featured Section -->
			<section class="mb-24 bg-zinc-900 rounded-sm overflow-hidden shadow-2xl border border-zinc-800">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-0 md:min-h-96">
					<div class="h-80 md:h-auto overflow-hidden group">
						<Image src={cateringImg} alt="Chef-driven catering" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
					</div>
					<div class="p-12 flex flex-col justify-center">
						<h2 class="text-3xl font-serif text-white mb-4">Chef Driven Catering</h2>
						<p class="text-zinc-300 leading-relaxed mb-6 font-light">
							From small intimate gatherings to chef-driven five-course dinners at your home or any venue in and surrounding Oak Bay and Greater Victoria, we are passionate about what we do, and we strive to ensure all our celebrations are exceptional.
						</p>
						<p class="text-orange-500 font-serif text-xl">
							We bring fine dining to you!
						</p>
					</div>
				</div>
			</section>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-16">
				<!-- Left Column -->
				<section class="mb-16 md:mb-0">
					<h2 class="text-3xl font-serif text-white mb-6">Our Offerings</h2>
					<ul class="text-zinc-300 leading-relaxed space-y-4 border-l-2 border-orange-500 pl-6">
						<li class="flex items-start gap-3">
							<span class="text-orange-500 mt-1">✦</span>
							<span>Canapés & Appetizers</span>
						</li>
						<li class="flex items-start gap-3">
							<span class="text-orange-500 mt-1">✦</span>
							<span>Charcuterie Boards</span>
						</li>
						<li class="flex items-start gap-3">
							<span class="text-orange-500 mt-1">✦</span>
							<span>Dessert Platters</span>
						</li>
						<li class="flex items-start gap-3">
							<span class="text-orange-500 mt-1">✦</span>
							<span>Family Style Dinners</span>
						</li>
						<li class="flex items-start gap-3">
							<span class="text-orange-500 mt-1">✦</span>
							<span>Custom Multi-Course Menus</span>
						</li>
					</ul>

					<a href={`${import.meta.env.BASE_URL}/menus/RECEPTION_CANAPE_2026.docx`} download class="inline-block mt-8 border border-orange-500 text-orange-500 px-6 py-3 uppercase tracking-widest text-sm hover:bg-orange-500 hover:text-white transition-all duration-300 font-semibold">
						Download Sample Canape Menu
					</a>
				</section>

				<!-- Right Column -->
				<section>
					<h2 class="text-3xl font-serif text-white mb-6">Philosophy</h2>
					<div class="bg-zinc-900 rounded-sm p-8 border border-zinc-800 mb-8">
						<p class="text-orange-500 font-serif text-xl mb-4">
							Farm Fueled ~ Chef Driven
						</p>
						<p class="text-zinc-300 leading-relaxed">
							All our catering uses the same philosophy as our restaurant: seasonal, locally sourced, and beautifully presented. We believe in creating memorable experiences through exceptional food.
						</p>
					</div>

					<h2 class="text-2xl font-serif text-white mb-4">Ready to Celebrate?</h2>
					<p class="text-zinc-400 text-sm mb-6">
						Let us help make your next event unforgettable with our chef-driven catering services.
					</p>
					<a href={`${import.meta.env.BASE_URL}/contact`} class="inline-block border border-orange-500 text-orange-500 px-6 py-2 uppercase tracking-widest text-sm hover:bg-orange-500 hover:text-white transition-all duration-300">
						Get In Touch
					</a>
				</section>
			</div>
		</main>
	</div>
</Layout>
