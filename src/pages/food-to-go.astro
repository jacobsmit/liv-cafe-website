---
// src/pages/food-to-go.astro
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<header class="bg-stone-200 py-12 text-center px-4">
		<h1 class="text-4xl font-bold text-stone-800">Food To Go</h1>
	</header>

	<main class="max-w-4xl mx-auto py-16 px-4">
		<section class="mb-12">
			<h2 class="text-2xl font-bold mb-4 text-stone-800">Market & Prepared Meals</h2>
			<p class="text-stone-600 leading-relaxed mb-4">
				Come on into our shop at 713 St. Patrick Street and see what we have in store! Fresh daily selection or frozen prepared meals easily popped in the oven for a hassle-free dinner.
			</p>
			<p class="text-stone-600 leading-relaxed">
				Or find some of our dishes exclusively on our subscription meal plan.
			</p>
		</section>

		<section class="mb-12">
			<h2 class="text-2xl font-bold mb-4 text-stone-800">What We Offer</h2>
			<ul class="text-stone-600 leading-relaxed space-y-2">
				<li>• Fresh daily prepared meals</li>
				<li>• Frozen prepared dinners</li>
				<li>• Seasonal produce from Liv's Edible Gardens</li>
				<li>• Exclusive subscription meal plans</li>
			</ul>
		</section>

		<section class="mb-12">
			<h2 class="text-2xl font-bold mb-4 text-stone-800">Subscription Meal Plan</h2>
			<p class="text-stone-600 leading-relaxed mb-4">
				Enjoy exclusive dishes through our subscription meal plan. Get restaurant-quality meals delivered to your door or ready for pickup.
			</p>
			<p class="text-stone-600 leading-relaxed">
				<a href="mailto:info@livcafeandbistro.com" class="text-emerald-600 hover:underline">Email us</a> for more details about subscribing.
			</p>
		</section>

		<section>
			<h2 class="text-2xl font-bold mb-4 text-stone-800">Visit Us</h2>
			<p class="text-stone-600 leading-relaxed mb-2">
				<strong>Location:</strong> 713 St. Patrick Street, Victoria, BC
			</p>
			<p class="text-stone-600 leading-relaxed mb-2">
				<strong>Phone:</strong> <a href="tel:(250) 590-5229" class="text-emerald-600 hover:underline">(250) 590-5229</a>
			</p>
			<p class="text-stone-600 leading-relaxed">
				<strong>Email:</strong> <a href="mailto:info@livcafeandbistro.com" class="text-emerald-600 hover:underline">info@livcafeandbistro.com</a>
			</p>
		</section>
	</main>
</Layout>
