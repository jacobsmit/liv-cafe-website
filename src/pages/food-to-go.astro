---
// src/pages/food-to-go.astro
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<div class="bg-zinc-950 text-zinc-300 min-h-screen font-sans selection:bg-orange-500 selection:text-white">
		<header class="relative py-20 px-4 border-b border-zinc-800">
			<div class="max-w-4xl mx-auto text-center">
				<h1 class="text-5xl md:text-6xl font-serif text-white mb-4 tracking-wide">Food To Go</h1>
				<div class="w-16 h-[2px] bg-orange-500 mx-auto"></div>
			</div>
		</header>

		<main class="max-w-4xl mx-auto py-20 px-4">
			<section class="mb-16">
				<h2 class="text-3xl font-serif text-white mb-6">Market & Prepared Meals</h2>
				<div class="border-l-2 border-orange-500 pl-6 space-y-4">
					<p class="text-zinc-300 leading-relaxed">
						Come on into our shop at 713 St. Patrick Street and see what we have in store! Fresh daily selection or frozen prepared meals easily popped in the oven for a hassle-free dinner.
					</p>
					<p class="text-zinc-300 leading-relaxed">
						Or find some of our dishes exclusively on our subscription meal plan.
					</p>
				</div>
			</section>

			<section class="mb-16">
				<h2 class="text-3xl font-serif text-white mb-6">What We Offer</h2>
				<ul class="text-zinc-300 leading-relaxed space-y-3 border-l-2 border-orange-500 pl-6">
					<li><span class="text-orange-500">•</span> Fresh daily prepared meals</li>
					<li><span class="text-orange-500">•</span> Frozen prepared dinners</li>
					<li><span class="text-orange-500">•</span> Seasonal produce from Liv's Edible Gardens</li>
					<li><span class="text-orange-500">•</span> Exclusive subscription meal plans</li>
				</ul>
			</section>

			<section class="mb-16">
				<h2 class="text-3xl font-serif text-white mb-6">Subscription Meal Plan</h2>
				<div class="border-l-2 border-orange-500 pl-6 space-y-4">
					<p class="text-zinc-300 leading-relaxed">
						Enjoy exclusive dishes through our subscription meal plan. Get restaurant-quality meals delivered to your door or ready for pickup.
					</p>
					<p class="text-zinc-300 leading-relaxed">
						<a href="mailto:info@livcafeandbistro.com" class="text-orange-500 hover:text-orange-400 transition-colors">Email us</a> for more details about subscribing.
					</p>
				</div>
			</section>

			<section>
				<h2 class="text-3xl font-serif text-white mb-6">Visit Us</h2>
				<div class="space-y-3">
					<p class="text-zinc-300 leading-relaxed">
						<span class="text-orange-500 font-serif">Location:</span> 713 St. Patrick Street, Victoria, BC
					</p>
					<p class="text-zinc-300 leading-relaxed">
						<span class="text-orange-500 font-serif">Phone:</span> <a href="tel:(250) 590-5229" class="text-orange-500 hover:text-orange-400 transition-colors">(250) 590-5229</a>
					</p>
					<p class="text-zinc-300 leading-relaxed">
						<span class="text-orange-500 font-serif">Email:</span> <a href="mailto:info@livcafeandbistro.com" class="text-orange-500 hover:text-orange-400 transition-colors">info@livcafeandbistro.com</a>
					</p>
				</div>
			</section>
		</main>
	</div>
</Layout>
