---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<header class="bg-stone-200 py-24 text-center px-4">
		<h1 class="text-5xl md:text-7xl font-bold text-stone-800 mb-6">Liv Café & Bistro</h1>
		<p class="text-xl text-stone-600 max-w-2xl mx-auto">
			A cocoon to live a little. Ingredient-driven dining in the heart of Oak Bay.
		</p>
	</header>

	<nav class="max-w-4xl mx-auto py-12 px-4">
		<ul class="flex flex-wrap justify-center gap-6 text-lg">
			<li><a href={`${import.meta.env.BASE_URL}about`} class="text-emerald-600 hover:underline">About</a></li>
			<li><a href={`${import.meta.env.BASE_URL}hours`} class="text-emerald-600 hover:underline">Hours</a></li>
			<li><a href={`${import.meta.env.BASE_URL}menu`} class="text-emerald-600 hover:underline">Menu</a></li>
			<li><a href={`${import.meta.env.BASE_URL}contact`} class="text-emerald-600 hover:underline">Reservations</a></li>
			<li><a href={`${import.meta.env.BASE_URL}catering`} class="text-emerald-600 hover:underline">Catering</a></li>
		</ul>
	</nav>

	<section class="max-w-4xl mx-auto py-16 px-4 text-center">
		<h2 class="text-2xl font-bold mb-4 text-stone-800">Nestled within Oak Bay</h2>
		<p class="text-stone-600 leading-relaxed mb-4">
			713 St. Patrick Street, Victoria, BC
		</p>
		<p class="text-stone-600 leading-relaxed">
			<a href="tel:(250) 590-5229" class="text-emerald-600 hover:underline">(250) 590-5229</a> | 
			<a href="mailto:info@livcafeandbistro.com" class="text-emerald-600 hover:underline">info@livcafeandbistro.com</a>
		</p>
	</section>
</Layout>