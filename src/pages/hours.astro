---
// src/pages/hours.astro
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<header class="bg-stone-200 py-12 text-center px-4">
		<h1 class="text-4xl font-bold text-stone-800">Hours & Location</h1>
	</header>

	<main class="max-w-4xl mx-auto py-16 px-4">
		<section class="mb-12">
			<h2 class="text-2xl font-bold mb-4 text-stone-800">Location</h2>
			<p class="text-stone-600 leading-relaxed">
				713 St. Patrick Street<br />
				Victoria, BC
			</p>
		</section>

		<section class="mb-12">
			<h2 class="text-2xl font-bold mb-4 text-stone-800">Brunch & Lunch</h2>
			<p class="text-stone-600 leading-relaxed mb-2">
				<strong>Wednesday to Friday</strong><br />
				10:00am – 2:30pm
			</p>
			<p class="text-stone-600 leading-relaxed">
				<strong>Saturday & Sunday</strong><br />
				9:30am – 2:30pm
			</p>
		</section>

		<section class="mb-12">
			<h2 class="text-2xl font-bold mb-4 text-stone-800">Dinner</h2>
			<p class="text-stone-600 leading-relaxed mb-4">
				<strong>Thursday to Saturday</strong><br />
				5:00pm – 9:00pm
			</p>
			<p class="text-stone-600 leading-relaxed text-sm">
				Coming soon to expand our dinner service.
			</p>
		</section>

		<section class="mb-12">
			<h2 class="text-2xl font-bold mb-4 text-stone-800">Closed</h2>
			<p class="text-stone-600 leading-relaxed">
				Monday & Tuesday
			</p>
		</section>

		<section class="mb-12">
			<h2 class="text-2xl font-bold mb-4 text-stone-800">Contact</h2>
			<p class="text-stone-600 leading-relaxed mb-2">
				<a href="tel:(250) 590-5229" class="text-emerald-600 hover:underline">(250) 590-5229</a>
			</p>
			<p class="text-stone-600 leading-relaxed">
				<a href="mailto:info@livcafeandbistro.com" class="text-emerald-600 hover:underline">info@livcafeandbistro.com</a>
			</p>
		</section>
	</main>
</Layout>
