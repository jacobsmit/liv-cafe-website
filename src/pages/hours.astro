---
// src/pages/hours.astro
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import hoursImg from '../assets/67b4e6fe71e6bd52cde977ea_IMG_6645.jpeg';
---

<Layout>
	<div class="bg-zinc-950 text-zinc-300 min-h-screen font-sans selection:bg-orange-500 selection:text-white">
		<header class="relative py-20 px-4 border-b border-zinc-800">
			<div class="max-w-4xl mx-auto text-center">
				<h1 class="text-5xl md:text-6xl font-serif text-white mb-4 tracking-wide">Hours & Location</h1>
				<div class="w-16 h-[2px] bg-orange-500 mx-auto"></div>
			</div>
		</header>

		<main class="max-w-6xl mx-auto py-20 px-4">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
				<!-- Left Column - Hours and Location Info -->
				<div>
					<section class="mb-16">
						<h2 class="text-3xl font-serif text-white mb-6">Location</h2>
						<div class="bg-zinc-900 p-8 rounded-sm border border-zinc-800">
							<p class="text-zinc-300 leading-relaxed text-lg font-light">
								713 St. Patrick Street<br />
								Victoria, BC
							</p>
							<p class="text-zinc-400 text-sm mt-6">
								Nestled in the heart of charming Oak Bay
							</p>
						</div>
					</section>

					<section class="mb-16">
						<h2 class="text-3xl font-serif text-white mb-6">Hours</h2>
						<div class="space-y-4 text-xl">
							<div class="flex justify-between border-b border-zinc-800 pb-3">
								<span class="text-white">Monday</span>
								<span class="text-zinc-400">Closed</span>
							</div>
							<div class="flex justify-between border-b border-zinc-800 pb-3">
								<span class="text-white">Tuesday</span>
								<span class="text-zinc-400">Closed</span>
							</div>
							<div class="flex justify-between border-b border-zinc-800 pb-3">
								<span class="text-white">Wednesday</span>
								<span class="text-zinc-300">10:00 am – 2:30 pm</span>
							</div>
							<div class="flex justify-between border-b border-zinc-800 pb-3">
								<span class="text-white">Thursday</span>
								<span class="text-zinc-300 text-right">10:00 am – 2:30 pm<br/><span class="text-orange-400 text-lg">Dinner:</span> 5:00 pm – 9:00 pm</span>
							</div>
							<div class="flex justify-between border-b border-zinc-800 pb-3">
								<span class="text-white">Friday</span>
								<span class="text-zinc-300 text-right">10:00 am – 2:30 pm<br/><span class="text-orange-400 text-lg">Dinner:</span> 5:00 pm – 9:00 pm</span>
							</div>
							<div class="flex justify-between border-b border-zinc-800 pb-3">
								<span class="text-white">Saturday</span>
								<span class="text-zinc-300 text-right">9:30 am – 2:30 pm<br/><span class="text-orange-400 text-lg">Dinner:</span> 5:00 pm – 9:00 pm</span>
							</div>
							<div class="flex justify-between pb-3">
								<span class="text-white">Sunday</span>
								<span class="text-zinc-300">9:30 am – 2:30 pm</span>
							</div>
						</div>
					</section>
				</div>

				<!-- Right Column - Image -->
				<div class="sticky top-8">
					<div class="h-96 md:h-[600px] rounded-sm shadow-2xl overflow-hidden group border border-zinc-800">
						<Image src={hoursImg} width={800} alt="Liv Café & Bistro location" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
					</div>
				</div>
			</div>

			<section>
				<h2 class="text-3xl font-serif text-white mb-6">Contact</h2>
				<div class="space-y-3">
					<p class="text-zinc-300">
						<a href="tel:2505905229" class="text-orange-500 hover:text-orange-400 transition-colors">(250) 590-5229</a>
					</p>
					<p class="text-zinc-300">
						<a href="mailto:info@livcafeandbistro.com" class="text-orange-500 hover:text-orange-400 transition-colors">info@livcafeandbistro.com</a>
					</p>
				</div>
			</section>
		</main>
	</div>
</Layout>
