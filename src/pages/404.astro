---
// src/pages/404.astro
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <main class="bg-zinc-950 text-zinc-300 min-h-[80vh] flex flex-col items-center justify-center text-center px-4">
        <h1 class="text-8xl md:text-9xl font-serif text-orange-500 mb-6">404</h1>
        <h2 class="text-3xl md:text-5xl font-serif text-white mb-8">Page Not Found</h2>
        <p class="text-xl text-zinc-400 mb-12 max-w-lg">
            We couldn't find the page you were looking for. It might have been moved or doesn't exist.
        </p>
        <a href={`${import.meta.env.BASE_URL}/`} class="inline-block bg-orange-500 text-white px-10 py-4 text-xl font-semibold rounded-sm hover:bg-orange-600 transition-colors shadow-lg">
            Return Home
        </a>
    </main>
</Layout>
