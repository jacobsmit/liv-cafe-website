---
import '../styles/global.css';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Liv Café & Bistro</title>
	</head>
	<body class="bg-stone-50 text-stone-900 font-sans min-h-screen flex flex-col">
		
		<!-- Navigation -->
		<nav class="bg-white shadow-sm p-4">
			<div class="max-w-4xl mx-auto flex justify-between items-center flex-wrap gap-4">
				<a href={import.meta.env.BASE_URL} class="text-2xl font-bold tracking-tighter text-stone-800">Liv Café & Bistro</a>
				<ul class="flex gap-4 font-medium text-stone-600 flex-wrap">
					<li><a href={`${import.meta.env.BASE_URL}/about`} class="hover:text-emerald-600 transition-colors">About</a></li>
					<li><a href={`${import.meta.env.BASE_URL}/hours`} class="hover:text-emerald-600 transition-colors">Hours</a></li>
					<li><a href={`${import.meta.env.BASE_URL}/menu`} class="hover:text-emerald-600 transition-colors">Menu</a></li>
					<li><a href={`${import.meta.env.BASE_URL}/contact`} class="hover:text-emerald-600 transition-colors">Reservations</a></li>
					<li><a href={`${import.meta.env.BASE_URL}/catering`} class="hover:text-emerald-600 transition-colors">Catering</a></li>
					<li><a href={`${import.meta.env.BASE_URL}/food-to-go`} class="hover:text-emerald-600 transition-colors">Food To Go</a></li>
				</ul>
			</div>
		</nav>

		<!-- Main Content is injected here -->
		<main class="flex-grow">
			<slot />
		</main>

		<!-- Footer -->
		<footer class="bg-stone-900 text-stone-300 py-8 mt-12">
			<div class="max-w-4xl mx-auto px-4">
				<div class="text-center mb-6">
					<p>&copy; 2026 Liv Café & Bistro.</p>
				</div>
				<div class="flex justify-center gap-6">
					<a href="https://www.instagram.com/livcafebistro/" target="_blank" rel="noopener noreferrer" class="hover:text-emerald-400 transition-colors" title="Instagram">
						<svg class="w-6 h-6 inline-block" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
							<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zM5.838 12a6.162 6.162 0 1 1 12.324 0 6.162 6.162 0 0 1-12.324 0zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm4.965-10.322a1.44 1.44 0 1 1 2.881.001 1.44 1.44 0 0 1-2.881-.001z"/>
						</svg>
					</a>
					<a href="https://www.facebook.com/p/Liv-Cafe-Bistro-61568156025948/" target="_blank" rel="noopener noreferrer" class="hover:text-emerald-400 transition-colors" title="Facebook">
						<svg class="w-6 h-6 inline-block" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
							<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
						</svg>
					</a>
				</div>
			</div>
		</footer>

	</body>
</html>